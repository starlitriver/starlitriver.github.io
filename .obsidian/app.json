{
  "promptDelete": false,
  "attachmentFolderPath": "./assets",
  "newFileLocation": "current",
  "newFileFolderPath": "~",
  "showInlineTitle": false,
  "livePreview": true,
  "showLineNumber": true,
  "showIndentGuide": true,
  "vimMode": false,
  "tabSize": 2,
  "strictLineBreaks": true,
  "pdfExportSettings": {
    "includeName": true,
    "pageSize": "A4",
    "landscape": false,
    "margin": "0",
    "downscalePercent": 100
  },
  "alwaysUpdateLinks": true,
  "useTab": false,
  "autoPairMarkdown": false,
  "spellcheck": true,
  "newLinkFormat": "shortest",
  "useMarkdownLinks": false,
  "userIgnoreFilters": [
    "node_modules/",
    "quartz/",
    "public/"
  ]
}